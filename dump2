# Step 1: Use an official, lightweight Python base image
FROM python:3.11-slim

# Step 2: Set the directory inside the container where commands will run
WORKDIR /app

# Step 3: Copy the requirements list first (allows caching for faster builds)
COPY requirements.txt .

# Step 4: Run the build tool (pip) to install dependencies inside the image
RUN pip install --no-cache-dir -r requirements.txt

# Step 5: Copy our application code file into the container
COPY app.py .

# Step 6: Expose the network port our app runs on
EXPOSE 8000

# Step 7: The execution command to run when the container starts up
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]


